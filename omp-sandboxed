#!/usr/bin/env bun
/**
 * Run Oh My Pi inside a macOS Seatbelt sandbox.
 *
 * Seatbelt confines filesystem access and host-process metadata. It does not
 * isolate the current UID, IPC, signals, credentials exposed to child processes,
 * or network egress. Use a separate OS user or VM for a stronger boundary.
 */

import { spawn, spawnSync } from "node:child_process";
import {
  X_OK,
  accessSync,
  existsSync,
  mkdtempSync,
  realpathSync,
  rmSync,
  statSync,
  writeFileSync,
} from "node:fs";
import { dirname, isAbsolute, join, relative, resolve, sep } from "node:path";
import process from "node:process";

const PROGRAM_NAME = "omp-sandboxed" as const;
const DEFAULT_PATH = "/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin" as const;
const SANDBOX_MARKER = "seatbelt" as const;
// Bun's node:http2 client can crash during OMP's first remote MCP handshake.
// The observed failure exits in about 1.9 seconds; retry only that startup window.
const STARTUP_RETRY_WINDOW_MS = 2_000;

const ENVIRONMENT_NAMES = {
  confirmSensitiveRead: "OMP_SANDBOX_CONFIRM_SENSITIVE_READ",
  confirmSensitiveWrite: "OMP_SANDBOX_CONFIRM_SENSITIVE_WRITE",
  confirmWide: "OMP_SANDBOX_CONFIRM_WIDE",
  extraRead: "OMP_SANDBOX_EXTRA_READ",
  extraWrite: "OMP_SANDBOX_EXTRA_WRITE",
  inherit: "OMP_SANDBOX_INHERIT_ENV",
  pass: "OMP_SANDBOX_PASS_ENV",
  skipHomeVerify: "OMP_SANDBOX_SKIP_HOME_VERIFY",
  workspace: "OMP_SANDBOX_WORKSPACE",
  yolo: "OMP_SANDBOX_YOLO",
} as const;

type EnvironmentName = (typeof ENVIRONMENT_NAMES)[keyof typeof ENVIRONMENT_NAMES];
type SourceEnvironment = Readonly<Record<string, string | undefined>>;
type ChildEnvironment = Record<string, string>;

declare const absolutePathBrand: unique symbol;
type AbsolutePath = string & { readonly [absolutePathBrand]: true };

interface CommandResult {
  readonly exitCode: number;
  readonly stderr: string;
  readonly stdout: string;
}

interface LaunchResult {
  readonly elapsedMilliseconds: number;
  readonly exitCode: number | null;
  readonly signal: NodeJS.Signals | null;
}

interface CommandOptions {
  readonly cwd?: AbsolutePath;
  readonly env?: ChildEnvironment;
}

interface ExtraPaths {
  readonly read: readonly AbsolutePath[];
  readonly write: readonly AbsolutePath[];
}

interface SandboxConfig {
  readonly cleanEnvironment: ChildEnvironment;
  readonly extraPaths: ExtraPaths;
  readonly home: AbsolutePath;
  readonly inheritEnvironment: boolean;
  readonly ompExecutable: AbsolutePath;
  readonly sandboxExecutable: AbsolutePath;
  readonly sourceEnvironment: SourceEnvironment;
  readonly temporaryDirectory: AbsolutePath;
  readonly workspace: AbsolutePath;
  readonly yolo: boolean;
}

interface TemporaryProfile {
  readonly directory: AbsolutePath;
  readonly file: AbsolutePath;
}

class ConfigurationError extends Error {
  public constructor(message: string) {
    super(message);
    this.name = "ConfigurationError";
  }
}


const HOST_EXECUTABLES = Object.freeze({
  bash: absolutePath("/bin/bash", "bash path"),
  dscl: absolutePath("/usr/bin/dscl", "dscl path"),
  env: absolutePath("/usr/bin/env", "env path"),
  id: absolutePath("/usr/bin/id", "id path"),
  ls: absolutePath("/bin/ls", "ls path"),
  ps: absolutePath("/bin/ps", "ps path"),
  pwd: absolutePath("/bin/pwd", "pwd path"),
  sandboxExec: absolutePath("/usr/bin/sandbox-exec", "sandbox-exec path"),
  stat: absolutePath("/usr/bin/stat", "stat path"),
});

const CLEAN_ENVIRONMENT_PASSTHROUGH = [
  "PATH",
  "USER",
  "LOGNAME",
  "SHELL",
  "LANG",
  "LC_ALL",
  "LC_CTYPE",
  "LC_MESSAGES",
  "TERM",
  "TERM_PROGRAM",
  "COLORTERM",
  "__CF_USER_TEXT_ENCODING",
  "COMMAND_MODE",
] as const;

/**
 * OMP can start OpenTelemetry paths backed by Bun's node:http2 implementation.
 * A configured OTLP/gRPC exporter is one trigger for the numeric `authority`
 * crash (825110816 / 0x312e3120), so disable every standard OTel signal. Remote
 * HTTP MCP startup is another trigger and is covered by the bounded retry below.
 * These values are applied last in clean and inherited modes and cannot be
 * overridden through OMP_SANDBOX_PASS_ENV.
 */
const TELEMETRY_KILL_SWITCHES = Object.freeze({
  OTEL_LOGS_EXPORTER: "none",
  OTEL_METRICS_EXPORTER: "none",
  OTEL_SDK_DISABLED: "true",
  OTEL_TRACES_EXPORTER: "none",
} satisfies Readonly<Record<string, string>>);

const CONTROLLED_ENVIRONMENT_NAMES = new Set<string>([
  "HOME",
  "TMPDIR",
  "OMP_SANDBOX",
  "PI_SANDBOX",
  ...Object.keys(TELEMETRY_KILL_SWITCHES),
]);

const SENSITIVE_HOME_PATHS = [
  ".ssh",
  ".aws",
  ".gnupg",
  ".netrc",
  ".netrc.gpg",
  "Library/Keychains",
  "Library/LaunchAgents",
  "Library/Application Support/Google",
  "Library/Safari",
  ".bashrc",
  ".bash_profile",
  ".zshrc",
  ".zprofile",
  ".profile",
] as const;

function absolutePath(value: string, label: string): AbsolutePath {
  if (!isAbsolute(value)) {
    throw new ConfigurationError(`${label} must be absolute: ${JSON.stringify(value)}`);
  }
  return value as AbsolutePath;
}

function joinedPath(base: AbsolutePath, ...parts: readonly string[]): AbsolutePath {
  return absolutePath(join(base, ...parts), "joined path");
}

function canonicalExistingDirectory(value: string, label: string): AbsolutePath {
  const candidate = absolutePath(resolve(value), label);
  let metadata: ReturnType<typeof statSync>;
  try {
    metadata = statSync(candidate);
  } catch {
    throw new ConfigurationError(`${label} does not exist: ${JSON.stringify(value)}`);
  }
  if (!metadata.isDirectory()) {
    throw new ConfigurationError(`${label} is not a directory: ${JSON.stringify(value)}`);
  }
  try {
    return absolutePath(realpathSync(candidate), label);
  } catch {
    // A parent Seatbelt profile can permit metadata for the directory node while
    // denying realpath(3)'s broader traversal. chdir(2) + pwd -P needs only the
    // access required by the original Bash wrapper and yields the same canonical path.
    const result = spawnSync(HOST_EXECUTABLES.pwd, ["-P"], {
      cwd: candidate,
      encoding: "utf8",
      stdio: ["ignore", "pipe", "pipe"],
    });
    const physicalPath = (result.stdout ?? "").trim();
    if (result.status === 0 && isAbsolute(physicalPath)) {
      return absolutePath(physicalPath, label);
    }
    throw new ConfigurationError(
      `${label} cannot be canonicalized: ${JSON.stringify(value)}`,
    );
  }
}

function expandHome(value: string, home: AbsolutePath): string {
  if (value === "~") return home;
  if (value.startsWith("~/")) return `${home}${value.slice(1)}`;
  return value;
}

function hasParentTraversal(value: string): boolean {
  return value.split(/[\\/]+/u).includes("..");
}

function canonicalExtraPath(rawValue: string, label: string): AbsolutePath {
  if (!isAbsolute(rawValue)) {
    throw new ConfigurationError(`${label} path must be absolute: ${JSON.stringify(rawValue)}`);
  }
  if (hasParentTraversal(rawValue)) {
    throw new ConfigurationError(
      `${label} path contains '..' and was rejected: ${JSON.stringify(rawValue)}`,
    );
  }

  const normalized = absolutePath(resolve(rawValue), `${label} path`);
  try {
    return absolutePath(realpathSync(normalized), `${label} path`);
  } catch {
    const parent = dirname(normalized);
    try {
      const canonicalParent = canonicalExistingDirectory(parent, `${label} parent`);
      return joinedPath(canonicalParent, normalized.slice(parent.length + (parent === "/" ? 0 : 1)));
    } catch {
      throw new ConfigurationError(
        `${label} path cannot be canonicalized because its parent does not exist: ${JSON.stringify(rawValue)}`,
      );
    }
  }
}

function isWithinOrEqual(parent: AbsolutePath, candidate: AbsolutePath): boolean {
  const difference = relative(parent, candidate);
  return (
    difference === "" ||
    (difference !== ".." && !difference.startsWith(`..${sep}`) && !isAbsolute(difference))
  );
}

function overlapsSensitiveHomePath(candidate: AbsolutePath, home: AbsolutePath): boolean {
  return SENSITIVE_HOME_PATHS.some((relativeSensitivePath: string): boolean => {
    const sensitive = joinedPath(home, relativeSensitivePath);
    return isWithinOrEqual(candidate, sensitive) || isWithinOrEqual(sensitive, candidate);
  });
}

function enabled(environment: SourceEnvironment, name: EnvironmentName): boolean {
  return environment[name] === "1";
}

function warn(message: string): void {
  console.error(`${PROGRAM_NAME}: warning: ${message}`);
}

function resolveExtraPathList(
  environment: SourceEnvironment,
  home: AbsolutePath,
  kind: "READ" | "WRITE",
): readonly AbsolutePath[] {
  const valueName = kind === "READ" ? ENVIRONMENT_NAMES.extraRead : ENVIRONMENT_NAMES.extraWrite;
  const confirmationName =
    kind === "READ"
      ? ENVIRONMENT_NAMES.confirmSensitiveRead
      : ENVIRONMENT_NAMES.confirmSensitiveWrite;
  const rawList = environment[valueName];
  if (rawList === undefined || rawList === "") return Object.freeze([]);

  const resolved: AbsolutePath[] = [];
  for (const rawEntry of rawList.split(":")) {
    if (rawEntry === "") continue;
    const candidate = canonicalExtraPath(expandHome(rawEntry, home), `EXTRA_${kind}`);
    if (overlapsSensitiveHomePath(candidate, home)) {
      if (!enabled(environment, confirmationName)) {
        throw new ConfigurationError(
          `EXTRA_${kind} path ${JSON.stringify(candidate)} covers a sensitive home location; ` +
            `set ${confirmationName}=1 to override (insecure)`,
        );
      }
      warn(
        `EXTRA_${kind} ${JSON.stringify(candidate)} covers a sensitive home location ` +
          `(${confirmationName}=1)`,
      );
    }
    resolved.push(candidate);
  }
  return Object.freeze([...new Set(resolved)]);
}

function resolveExtraPaths(environment: SourceEnvironment, home: AbsolutePath): ExtraPaths {
  return Object.freeze({
    read: resolveExtraPathList(environment, home, "READ"),
    write: resolveExtraPathList(environment, home, "WRITE"),
  });
}

function runCommand(
  executable: AbsolutePath,
  arguments_: readonly string[],
  options: CommandOptions = {},
): CommandResult {
  const result = spawnSync(executable, [...arguments_], {
    cwd: options.cwd,
    encoding: "utf8",
    env: options.env,
    stdio: ["ignore", "pipe", "pipe"],
  });
  if (result.error !== undefined) throw result.error;
  return Object.freeze({
    exitCode: result.status ?? 1,
    stderr: result.stderr ?? "",
    stdout: result.stdout ?? "",
  });
}

function assertExecutable(path: AbsolutePath, label: string): void {
  try {
    accessSync(path, X_OK);
  } catch {
    throw new ConfigurationError(`${label} is not executable: ${path}`);
  }
}

function findExecutable(
  name: string,
  pathValue: string | undefined,
  workingDirectory: AbsolutePath,
): AbsolutePath | undefined {
  if (name.includes("/")) {
    const explicit = absolutePath(resolve(workingDirectory, name), `${name} path`);
    try {
      accessSync(explicit, X_OK);
      return explicit;
    } catch {
      return undefined;
    }
  }

  for (const pathEntry of (pathValue ?? DEFAULT_PATH).split(":")) {
    const directory = pathEntry === "" ? workingDirectory : resolve(workingDirectory, pathEntry);
    const candidate = absolutePath(resolve(directory, name), `${name} path`);
    try {
      accessSync(candidate, X_OK);
      if (statSync(candidate).isFile()) return candidate;
    } catch {
      // Continue to the next PATH entry.
    }
  }
  return undefined;
}

function resolveVerifiedHome(environment: SourceEnvironment): AbsolutePath {
  const skipVerification = enabled(environment, ENVIRONMENT_NAMES.skipHomeVerify);
  const userResult = runCommand(HOST_EXECUTABLES.id, ["-un"]);
  const userName = userResult.stdout.trim();
  let verifiedHome: AbsolutePath | undefined;

  if (userResult.exitCode === 0 && userName !== "") {
    const directoryServiceResult = runCommand(HOST_EXECUTABLES.dscl, [
      ".",
      "-read",
      `/Users/${userName}`,
      "NFSHomeDirectory",
    ]);
    const prefix = "NFSHomeDirectory: ";
    const output = directoryServiceResult.stdout.trimEnd();
    if (directoryServiceResult.exitCode === 0 && output.startsWith(prefix)) {
      const reportedHome = output.slice(prefix.length);
      verifiedHome = canonicalExistingDirectory(reportedHome, "directory-service home");
    }
  }

  if (verifiedHome === undefined) {
    if (!skipVerification) {
      throw new ConfigurationError(
        "could not verify the user home with /usr/bin/dscl; " +
          `${ENVIRONMENT_NAMES.skipHomeVerify}=1 uses inherited HOME (insecure)`,
      );
    }
    const inheritedHome = environment.HOME;
    if (inheritedHome === undefined || inheritedHome === "") {
      throw new ConfigurationError("HOME is unset");
    }
    warn(
      `directory-service home lookup failed; using inherited HOME ` +
        `(${ENVIRONMENT_NAMES.skipHomeVerify}=1)`,
    );
    return canonicalExistingDirectory(inheritedHome, "inherited HOME");
  }

  if (environment.HOME !== verifiedHome) {
    if (!skipVerification) {
      throw new ConfigurationError(
        `inherited HOME (${JSON.stringify(environment.HOME ?? "")}) differs from the real user home ` +
          `${JSON.stringify(verifiedHome)}; refusing a read-policy bypass. ` +
          `Set ${ENVIRONMENT_NAMES.skipHomeVerify}=1 to override (insecure)`,
      );
    }
    warn(
      `inherited HOME (${JSON.stringify(environment.HOME ?? "")}) differs from the real home ` +
        `${JSON.stringify(verifiedHome)}; using the real home ` +
        `(${ENVIRONMENT_NAMES.skipHomeVerify}=1)`,
    );
  }
  return verifiedHome;
}

function resolveTemporaryDirectory(environment: SourceEnvironment): AbsolutePath {
  const rawTemporaryDirectory = environment.TMPDIR ?? "/tmp";
  let candidate: AbsolutePath;
  try {
    candidate = canonicalExistingDirectory(rawTemporaryDirectory, "TMPDIR");
  } catch {
    warn(`TMPDIR (${JSON.stringify(rawTemporaryDirectory)}) is unusable; using /private/tmp`);
    return canonicalExistingDirectory("/private/tmp", "fallback TMPDIR");
  }

  if (
    candidate === "/private/tmp" ||
    candidate.startsWith("/private/tmp/") ||
    candidate.startsWith("/private/var/folders/")
  ) {
    return candidate;
  }

  warn(
    `TMPDIR (${JSON.stringify(candidate)}) is not a known macOS scratch root; ` +
      "using /private/tmp for policy",
  );
  return canonicalExistingDirectory("/private/tmp", "fallback TMPDIR");
}

function copyEnvironmentValue(
  destination: ChildEnvironment,
  source: SourceEnvironment,
  name: string,
): void {
  const value = source[name];
  if (value !== undefined && value !== "") destination[name] = value;
}

function buildCleanEnvironment(
  source: SourceEnvironment,
  home: AbsolutePath,
  temporaryDirectory: AbsolutePath,
): ChildEnvironment {
  const clean: ChildEnvironment = {};
  for (const name of CLEAN_ENVIRONMENT_PASSTHROUGH) copyEnvironmentValue(clean, source, name);

  const requestedVariables = source[ENVIRONMENT_NAMES.pass];
  if (requestedVariables !== undefined && requestedVariables !== "") {
    for (const name of requestedVariables.split(":")) {
      if (name === "") continue;
      if (!/^[A-Za-z_][A-Za-z0-9_]*$/u.test(name)) {
        throw new ConfigurationError(
          `${ENVIRONMENT_NAMES.pass} contains an invalid environment name: ${JSON.stringify(name)}`,
        );
      }
      if (CONTROLLED_ENVIRONMENT_NAMES.has(name)) {
        warn(`${ENVIRONMENT_NAMES.pass}: ${JSON.stringify(name)} is wrapper-controlled and was ignored`);
        continue;
      }
      const value = source[name];
      if (value === undefined || value === "") {
        warn(`${ENVIRONMENT_NAMES.pass}: ${JSON.stringify(name)} is unset or empty`);
      } else {
        clean[name] = value;
      }
    }
  }

  clean.HOME = home;
  clean.TMPDIR = temporaryDirectory;
  clean.OMP_SANDBOX = SANDBOX_MARKER;
  clean.PI_SANDBOX = SANDBOX_MARKER;
  Object.assign(clean, TELEMETRY_KILL_SWITCHES);
  return clean;
}

function buildInheritedEnvironment(config: SandboxConfig): ChildEnvironment {
  const inherited: ChildEnvironment = {};
  for (const [name, value] of Object.entries(config.sourceEnvironment)) {
    if (value !== undefined) inherited[name] = value;
  }
  inherited.HOME = config.home;
  inherited.TMPDIR = config.temporaryDirectory;
  inherited.OMP_SANDBOX = SANDBOX_MARKER;
  inherited.PI_SANDBOX = SANDBOX_MARKER;
  Object.assign(inherited, TELEMETRY_KILL_SWITCHES);
  return inherited;
}

function loadConfig(
  sourceEnvironment: SourceEnvironment = process.env,
  currentDirectory: string = process.cwd(),
): SandboxConfig {
  const cwd = canonicalExistingDirectory(currentDirectory, "current working directory");
  const sandboxExecutable = HOST_EXECUTABLES.sandboxExec;
  assertExecutable(sandboxExecutable, "/usr/bin/sandbox-exec");

  const ompExecutable = findExecutable("omp", sourceEnvironment.PATH, cwd);
  if (ompExecutable === undefined) {
    throw new ConfigurationError("'omp' was not found on PATH");
  }

  const home = resolveVerifiedHome(sourceEnvironment);
  const rawWorkspace = sourceEnvironment[ENVIRONMENT_NAMES.workspace] ?? cwd;
  const workspace = canonicalExistingDirectory(
    expandHome(rawWorkspace, home),
    "sandbox workspace",
  );
  if (workspace === "/" || workspace === home) {
    if (!enabled(sourceEnvironment, ENVIRONMENT_NAMES.confirmWide)) {
      throw new ConfigurationError(
        `workspace ${JSON.stringify(workspace)} grants very broad access; ` +
          `set ${ENVIRONMENT_NAMES.confirmWide}=1 to override`,
      );
    }
    warn(
      `workspace ${JSON.stringify(workspace)} grants very broad access ` +
        `(${ENVIRONMENT_NAMES.confirmWide}=1)`,
    );
  }

  const temporaryDirectory = resolveTemporaryDirectory(sourceEnvironment);
  const extraPaths = resolveExtraPaths(sourceEnvironment, home);
  const cleanEnvironment = buildCleanEnvironment(sourceEnvironment, home, temporaryDirectory);

  return Object.freeze({
    cleanEnvironment,
    extraPaths,
    home,
    inheritEnvironment: enabled(sourceEnvironment, ENVIRONMENT_NAMES.inherit),
    ompExecutable,
    sandboxExecutable,
    sourceEnvironment,
    temporaryDirectory,
    workspace,
    yolo: enabled(sourceEnvironment, ENVIRONMENT_NAMES.yolo),
  });
}

function escapeSeatbeltString(value: string): string {
  if (/[\0\r\n]/u.test(value)) {
    throw new ConfigurationError(
      `a profile path contains a NUL or line break: ${JSON.stringify(value)}`,
    );
  }
  return value.replaceAll("\\", "\\\\").replaceAll('"', '\\"');
}

function uniquePaths(paths: readonly AbsolutePath[]): readonly AbsolutePath[] {
  return [...new Set(paths)];
}

function renderSubpaths(paths: readonly AbsolutePath[]): string {
  return uniquePaths(paths)
    .map((path: AbsolutePath): string => `    (subpath "${escapeSeatbeltString(path)}")`)
    .join("\n");
}

function generateProfile(config: SandboxConfig, extraPaths: ExtraPaths = config.extraPaths): string {
  const writePaths = [
    config.workspace,
    absolutePath("/private/tmp", "private temporary path"),
    config.temporaryDirectory,
    joinedPath(config.home, ".omp"),
    ...extraPaths.write,
  ] as const;
  const readPaths = [
    joinedPath(config.home, ".omp"),
    joinedPath(config.home, ".bun"),
    config.workspace,
    ...extraPaths.read,
  ] as const;
  const escapedHome = escapeSeatbeltString(config.home);

  return `(version 1)
(allow default)

;; Deny host-process enumeration while retaining self-inspection.
(deny process-info*)
(allow process-info* (target self))

;; Deny writes globally, then allow only the workspace and runtime state.
(deny file-write*)
(allow file-write*
${renderSubpaths(writePaths)})
(allow file-write*
    (subpath "/private/var/folders")
    (subpath "/dev"))

;; Deny reads under HOME, then allow only explicit subtrees.
(deny file-read* (subpath "${escapedHome}"))
(allow file-read*
${renderSubpaths(readPaths)})

;; Go path canonicalization needs metadata for the HOME node itself. This does
;; not permit readdir or file data beneath HOME.
(allow file-read-metadata (literal "${escapedHome}"))
`;
}

function createTemporaryProfile(config: SandboxConfig, profile: string): TemporaryProfile {
  const directory = absolutePath(
    mkdtempSync(join(config.temporaryDirectory, "omp-sandbox-")),
    "temporary profile directory",
  );
  const file = joinedPath(directory, "profile.sb");
  try {
    writeFileSync(file, profile, { encoding: "utf8", mode: 0o600, flag: "wx" });
  } catch (error: unknown) {
    rmSync(directory, { recursive: true, force: true });
    throw error;
  }
  return Object.freeze({ directory, file });
}

function removeTemporaryProfile(profile: TemporaryProfile): void {
  rmSync(profile.directory, { recursive: true, force: true });
}

function sandboxCommand(
  config: SandboxConfig,
  profileFile: AbsolutePath,
  executable: AbsolutePath,
  arguments_: readonly string[],
  environment: ChildEnvironment = config.cleanEnvironment,
): CommandResult {
  return runCommand(
    config.sandboxExecutable,
    ["-f", profileFile, executable, ...arguments_],
    { cwd: config.workspace, env: environment },
  );
}

function withEnvironment(
  base: ChildEnvironment,
  additions: Readonly<Record<string, string>>,
): ChildEnvironment {
  return Object.assign({}, base, additions);
}

class SelfTestReporter {
  #failureCount = 0;

  public check(label: string, passed: boolean, details?: string): void {
    if (passed) {
      console.log(`PASS: ${label}`);
      return;
    }
    this.#failureCount += 1;
    console.log(`FAIL: ${label}${details === undefined || details === "" ? "" : ` — ${details}`}`);
  }

  public skip(label: string, reason: string): void {
    console.log(`SKIP: ${label} (${reason})`);
  }

  public get exitCode(): number {
    return this.#failureCount === 0 ? 0 : 1;
  }
}

function outputHasEnvironmentLine(output: string, name: string, value: string): boolean {
  return output.split("\n").includes(`${name}=${value}`);
}

function commandWasDeniedInsideSandbox(result: CommandResult): boolean {
  return result.exitCode !== 0 && !result.stderr.includes("sandbox_apply:");
}

function runSelfTest(config: SandboxConfig): number {
  const reporter = new SelfTestReporter();
  if (process.env.OMP_SANDBOX === SANDBOX_MARKER) {
    console.error(
      `${PROGRAM_NAME}: note: already running under Seatbelt; macOS rejects nested sandbox-exec ` +
        "profiles, so sandbox boundary checks are expected to fail here",
    );
  }

  for (const [name, expected] of Object.entries(TELEMETRY_KILL_SWITCHES)) {
    reporter.check(
      `clean environment sets ${name}=${expected}`,
      config.cleanEnvironment[name] === expected,
    );
  }
  const inheritedEnvironment = buildInheritedEnvironment(config);
  for (const [name, expected] of Object.entries(TELEMETRY_KILL_SWITCHES)) {
    reporter.check(
      `inherited environment forces ${name}=${expected}`,
      inheritedEnvironment[name] === expected,
    );
  }

  const telemetryEnvironmentResult = runCommand(HOST_EXECUTABLES.env, [], {
    env: config.cleanEnvironment,
  });
  reporter.check(
    "OTel kill-switches reach a clean-environment child",
    telemetryEnvironmentResult.exitCode === 0 &&
      Object.entries(TELEMETRY_KILL_SWITCHES).every(([name, value]): boolean =>
        outputHasEnvironmentLine(telemetryEnvironmentResult.stdout, name, value),
      ),
  );

  const temporaryProfile = createTemporaryProfile(config, generateProfile(config));
  const profileFile = temporaryProfile.file;
  const probeEnvironment = withEnvironment(config.cleanEnvironment, {
    _SBX_HOME_PROBE: joinedPath(config.home, `.omp-sandbox-probe-${process.pid}`),
    _SBX_OMP_PROBE: joinedPath(config.home, ".omp", ".omp-sandbox-probe"),
    _SBX_WS: config.workspace,
    _SBX_WS_PROBE: joinedPath(config.workspace, ".omp-sandbox-probe"),
  });

  try {
    let result = sandboxCommand(
      config,
      profileFile,
      HOST_EXECUTABLES.bash,
      ["-c", 'echo ok > "$_SBX_WS_PROBE" && rm -f "$_SBX_WS_PROBE"'],
      probeEnvironment,
    );
    reporter.check("workspace write allowed", result.exitCode === 0, result.stderr.trim());

    result = sandboxCommand(config, profileFile, HOST_EXECUTABLES.bash, [
      "-c",
      "echo x > /etc/.omp-sandbox-probe && rm -f /etc/.omp-sandbox-probe",
    ]);
    reporter.check("/etc write denied", commandWasDeniedInsideSandbox(result), result.stderr.trim());

    const homeWriteShouldBeDenied =
      !isWithinOrEqual(config.workspace, config.home) &&
      !config.extraPaths.write.some((path: AbsolutePath): boolean =>
        isWithinOrEqual(path, config.home),
      );
    if (homeWriteShouldBeDenied) {
      result = sandboxCommand(
        config,
        profileFile,
        HOST_EXECUTABLES.bash,
        ["-c", 'echo x > "$_SBX_HOME_PROBE"'],
        probeEnvironment,
      );
      reporter.check(
        "HOME write denied",
        commandWasDeniedInsideSandbox(result),
        result.stderr.trim(),
      );
      if (result.exitCode === 0) rmSync(probeEnvironment._SBX_HOME_PROBE, { force: true });
    } else {
      reporter.skip("HOME write denied", "HOME is covered by a write allowlist");
    }

    result = sandboxCommand(
      config,
      profileFile,
      HOST_EXECUTABLES.bash,
      ["-c", 'echo x > "$_SBX_OMP_PROBE" && rm -f "$_SBX_OMP_PROBE"'],
      probeEnvironment,
    );
    reporter.check("~/.omp write allowed", result.exitCode === 0, result.stderr.trim());

    result = sandboxCommand(config, profileFile, HOST_EXECUTABLES.ls, [
      joinedPath(config.home, ".omp"),
    ]);
    reporter.check("~/.omp read allowed", result.exitCode === 0, result.stderr.trim());

    result = sandboxCommand(config, profileFile, HOST_EXECUTABLES.ls, [config.workspace]);
    reporter.check("workspace read allowed", result.exitCode === 0, result.stderr.trim());

    const deniedHomeLocations = [
      joinedPath(config.home, "Library", "Keychains"),
      joinedPath(config.home, "Library", "Messages"),
      joinedPath(config.home, "Library", "Mobile Documents"),
    ] as const;
    for (const location of deniedHomeLocations) {
      if (!existsSync(location)) continue;
      result = sandboxCommand(config, profileFile, HOST_EXECUTABLES.ls, [location]);
      reporter.check(
        `${location.slice(config.home.length + 1)} read denied`,
        commandWasDeniedInsideSandbox(result),
        result.stderr.trim(),
      );
    }

    result = sandboxCommand(config, profileFile, HOST_EXECUTABLES.ps, ["-axo", "pid="]);
    reporter.check(
      "host process enumeration denied",
      commandWasDeniedInsideSandbox(result),
      result.stderr.trim(),
    );

    result = sandboxCommand(config, profileFile, HOST_EXECUTABLES.bash, ["-c", "echo ok"]);
    reporter.check("ordinary child execution allowed", result.exitCode === 0, result.stderr.trim());

    result = sandboxCommand(config, profileFile, config.ompExecutable, ["--version"]);
    reporter.check(
      "omp boots under the sandbox clean environment",
      result.exitCode === 0 && result.stdout.startsWith("omp/"),
      result.stderr.trim(),
    );

    result = sandboxCommand(config, profileFile, config.ompExecutable, [
      "--auto-approve",
      "--version",
    ]);
    reporter.check(
      "omp accepts --auto-approve",
      result.exitCode === 0 && /^\d/u.test(result.stdout),
      result.stderr.trim(),
    );

    result = sandboxCommand(config, profileFile, HOST_EXECUTABLES.env, []);
    reporter.check(
      "sandbox environment markers are set",
      result.exitCode === 0 &&
        outputHasEnvironmentLine(result.stdout, "OMP_SANDBOX", SANDBOX_MARKER) &&
        outputHasEnvironmentLine(result.stdout, "PI_SANDBOX", SANDBOX_MARKER),
    );

    reporter.check(
      `TMPDIR scratch root is valid (${config.temporaryDirectory})`,
      config.temporaryDirectory === "/private/tmp" ||
        config.temporaryDirectory.startsWith("/private/tmp/") ||
        config.temporaryDirectory.startsWith("/private/var/folders/"),
    );

    const canaryEnvironment = withEnvironment(config.cleanEnvironment, {
      _SBX_SECRET_CANARY: `omp-sandbox-canary-${process.pid}`,
    });
    const cleanChildResult = sandboxCommand(
      config,
      profileFile,
      HOST_EXECUTABLES.env,
      [],
      config.cleanEnvironment,
    );
    reporter.check(
      "non-allowlisted secret canary is absent from clean environment",
      canaryEnvironment._SBX_SECRET_CANARY !== undefined &&
        !cleanChildResult.stdout.includes("_SBX_SECRET_CANARY="),
    );

    reporter.check(
      ".ssh is detected as a sensitive EXTRA_WRITE target",
      overlapsSensitiveHomePath(joinedPath(config.home, ".ssh"), config.home),
    );

    result = sandboxCommand(config, profileFile, HOST_EXECUTABLES.stat, [
      "-f",
      "%Su",
      config.home,
    ]);
    reporter.check("HOME node metadata stat allowed", result.exitCode === 0, result.stderr.trim());

    result = sandboxCommand(config, profileFile, HOST_EXECUTABLES.ls, [config.home]);
    reporter.check(
      "HOME node readdir remains denied",
      commandWasDeniedInsideSandbox(result),
      result.stderr.trim(),
    );

    const unconfirmedSensitiveReadEnvironment: SourceEnvironment = {
      ...config.sourceEnvironment,
      [ENVIRONMENT_NAMES.confirmSensitiveRead]: undefined,
      [ENVIRONMENT_NAMES.extraRead]: joinedPath(config.home, ".ssh"),
    };
    let sensitiveReadRejected = false;
    try {
      resolveExtraPathList(unconfirmedSensitiveReadEnvironment, config.home, "READ");
    } catch (error: unknown) {
      sensitiveReadRejected =
        error instanceof ConfigurationError && error.message.includes("sensitive home location");
    }
    reporter.check("EXTRA_READ rejects ~/.ssh without confirmation", sensitiveReadRejected);

    const confirmedSensitiveReadEnvironment: SourceEnvironment = {
      ...unconfirmedSensitiveReadEnvironment,
      [ENVIRONMENT_NAMES.confirmSensitiveRead]: "1",
    };
    const confirmedSensitiveRead = resolveExtraPathList(
      confirmedSensitiveReadEnvironment,
      config.home,
      "READ",
    );
    reporter.check(
      "EXTRA_READ allows ~/.ssh with confirmation",
      confirmedSensitiveRead.includes(joinedPath(config.home, ".ssh")) &&
        generateProfile(config, { read: confirmedSensitiveRead, write: [] }).includes(
          `(subpath "${escapeSeatbeltString(joinedPath(config.home, ".ssh"))}")`,
        ),
    );

    runExtraReadCanaryTest(config, profileFile, reporter);
    runMnemonTest(config, reporter);
  } finally {
    removeTemporaryProfile(temporaryProfile);
  }

  return reporter.exitCode;
}

function runExtraReadCanaryTest(
  config: SandboxConfig,
  baselineProfileFile: AbsolutePath,
  reporter: SelfTestReporter,
): void {
  let canaryRoot: AbsolutePath | undefined;
  let extraProfile: TemporaryProfile | undefined;
  try {
    canaryRoot = absolutePath(
      mkdtempSync(join(config.home, ".omp-sandbox-extra-read-")),
      "EXTRA_READ canary directory",
    );
    const canaryFile = joinedPath(canaryRoot, "canary");
    writeFileSync(canaryFile, "extra-read-canary\n", { encoding: "utf8", mode: 0o600 });
    const environment = withEnvironment(config.cleanEnvironment, { _SBX_CANARY: canaryFile });

    const baselineResult = sandboxCommand(
      config,
      baselineProfileFile,
      HOST_EXECUTABLES.bash,
      ["-c", 'cat "$_SBX_CANARY" >/dev/null'],
      environment,
    );
    if (!commandWasDeniedInsideSandbox(baselineResult)) {
      reporter.check(
        "EXTRA_READ baseline denies canary",
        false,
        baselineResult.exitCode === 0
          ? "canary was already readable"
          : baselineResult.stderr.trim(),
      );
      return;
    }
    reporter.check("EXTRA_READ baseline denies canary", true);

    const extraPaths: ExtraPaths = { read: [canaryRoot], write: [] };
    extraProfile = createTemporaryProfile(config, generateProfile(config, extraPaths));
    const allowedResult = sandboxCommand(
      config,
      extraProfile.file,
      HOST_EXECUTABLES.bash,
      ["-c", 'cat "$_SBX_CANARY" >/dev/null'],
      environment,
    );
    reporter.check(
      "EXTRA_READ canary is readable when allowlisted",
      allowedResult.exitCode === 0,
      allowedResult.stderr.trim(),
    );
  } catch (error: unknown) {
    reporter.check(
      "EXTRA_READ end-to-end canary",
      false,
      error instanceof Error ? error.message : String(error),
    );
  } finally {
    if (extraProfile !== undefined) removeTemporaryProfile(extraProfile);
    if (canaryRoot !== undefined) rmSync(canaryRoot, { recursive: true, force: true });
  }
}

function runMnemonTest(config: SandboxConfig, reporter: SelfTestReporter): void {
  const store = joinedPath(config.home, ".mnemon");
  const executable = findExecutable("mnemon", config.sourceEnvironment.PATH, config.workspace);
  if (!existsSync(store) || executable === undefined) {
    reporter.skip("mnemon store reachable", "mnemon is not installed or ~/.mnemon is absent");
    return;
  }

  const profile = createTemporaryProfile(
    config,
    generateProfile(config, { read: [store], write: [store] }),
  );
  try {
    const result = sandboxCommand(config, profile.file, executable, [
      "recall",
      "__omp_sandbox_selftest__",
      "--limit",
      "1",
    ]);
    reporter.check(
      "mnemon store reachable under explicit read/write allowlists",
      result.exitCode === 0 && result.stdout.includes('"id"'),
      result.stderr.trim(),
    );
  } finally {
    removeTemporaryProfile(profile);
  }
}

async function runSandboxedOmp(
  config: SandboxConfig,
  profile: string,
  arguments_: readonly string[],
  environment: ChildEnvironment,
): Promise<LaunchResult> {
  const startedAt = performance.now();
  const child = spawn(
    config.sandboxExecutable,
    ["-p", profile, config.ompExecutable, ...arguments_],
    {
      cwd: config.workspace,
      env: environment,
      stdio: "inherit",
    },
  );

  // The child remains in this foreground process group and inherits the TTY
  // descriptors, so terminal-generated signals and window changes reach it
  // directly. Keep the supervisor alive while OMP handles Ctrl-C/Ctrl-\ itself,
  // and relay lifecycle signals that may be sent only to the wrapper PID.
  const retainSupervisor = (): void => {};
  const forwardSignal = (signal: NodeJS.Signals): void => {
    if (child.exitCode === null && child.signalCode === null) child.kill(signal);
  };
  const forwardHangup = (): void => forwardSignal("SIGHUP");
  const forwardTermination = (): void => forwardSignal("SIGTERM");
  process.on("SIGINT", retainSupervisor);
  process.on("SIGQUIT", retainSupervisor);
  process.on("SIGHUP", forwardHangup);
  process.on("SIGTERM", forwardTermination);

  try {
    const result = await new Promise<{
      readonly exitCode: number | null;
      readonly signal: NodeJS.Signals | null;
    }>((resolvePromise, rejectPromise): void => {
      child.once("error", rejectPromise);
      child.once("exit", (exitCode, signal): void => {
        resolvePromise({ exitCode, signal });
      });
    });
    return Object.freeze({
      elapsedMilliseconds: performance.now() - startedAt,
      ...result,
    });
  } finally {
    process.off("SIGINT", retainSupervisor);
    process.off("SIGQUIT", retainSupervisor);
    process.off("SIGHUP", forwardHangup);
    process.off("SIGTERM", forwardTermination);
  }
}

async function launch(config: SandboxConfig, arguments_: readonly string[]): Promise<number> {
  const childEnvironment = config.inheritEnvironment
    ? buildInheritedEnvironment(config)
    : config.cleanEnvironment;
  if (config.inheritEnvironment) {
    warn(`${ENVIRONMENT_NAMES.inherit}=1 passes the full parent environment (insecure)`);
  }

  const ompArguments = config.yolo ? ["--auto-approve", ...arguments_] : [...arguments_];
  const profile = generateProfile(config);
  process.chdir(config.workspace);

  for (let attempt = 0; ; attempt += 1) {
    const result = await runSandboxedOmp(config, profile, ompArguments, childEnvironment);
    if (result.signal !== null) {
      process.kill(process.pid, result.signal);
      return 1;
    }

    const exitCode = result.exitCode ?? 1;
    const shouldRetry =
      attempt === 0 &&
      exitCode !== 0 &&
      result.elapsedMilliseconds <= STARTUP_RETRY_WINDOW_MS;
    if (!shouldRetry) return exitCode;

    warn(
      `omp exited with code ${exitCode} after ${Math.round(result.elapsedMilliseconds)}ms; ` +
        "retrying startup once",
    );
  }
}

async function main(arguments_: readonly string[] = process.argv.slice(2)): Promise<number> {
  const config = loadConfig();
  if (arguments_[0] === "--print-profile") {
    process.stdout.write(generateProfile(config));
    return 0;
  }
  if (arguments_[0] === "--self-test") return runSelfTest(config);
  return launch(config, arguments_);
}

if (import.meta.main) {
  try {
    process.exitCode = await main();
  } catch (error: unknown) {
    const message = error instanceof Error ? error.message : String(error);
    console.error(`${PROGRAM_NAME}: error: ${message}`);
    process.exitCode = 1;
  }
}
